#!/bin/bash
set -uo pipefail

# Interactive branch deletion tool.
# Lists local branches sorted by last commit time (oldest first),
# then lets you pick which ones to delete by number.

# Protected branches that cannot be deleted
protected_branches=("main" "master")

is_protected() {
    local branch="$1"
    for p in "${protected_branches[@]}"; do
        [[ "$branch" == "$p" ]] && return 0
    done
    return 1
}

echo "Local branches (ordered by last commit time, oldest first):"
echo "--------------------------------------------------------"

# Create array to store branch info
declare -a branches
i=0

# Collect all branch info — use git's %ct format to get epoch directly (portable)
while IFS= read -r branch; do
    # Skip if branch is current branch
    [[ "$branch" == "*"* ]] && continue

    branch=$(echo "$branch" | tr -d ' ')

    # Get epoch timestamp and last commit info directly from git
    epoch=$(git log -1 --pretty=format:"%ct" "$branch" 2>/dev/null || echo "0")
    last_commit_msg=$(git log -1 --pretty=format:"%s" "$branch" 2>/dev/null || echo "")

    branches[$i]="$epoch|$branch|$last_commit_msg"

    ((i++))
done < <(git branch)

# Sort branches by last commit date (oldest first) and print
i=0
while IFS= read -r branch_info; do
    IFS='|' read -r epoch branch last_commit_msg <<< "$branch_info"

    # Calculate time difference
    now=$(date +%s)
    diff=$((now - epoch))

    # Format time difference as "X days/hours/mins ago"
    if [ "$diff" -ge 86400 ]; then
        days=$((diff / 86400))
        time_ago="${days} day"
        [ "$days" -ne 1 ] && time_ago="${time_ago}s"
        time_ago="${time_ago} ago"
    elif [ "$diff" -ge 3600 ]; then
        hours=$((diff / 3600))
        time_ago="${hours} hour"
        [ "$hours" -ne 1 ] && time_ago="${time_ago}s"
        time_ago="${time_ago} ago"
    else
        mins=$((diff / 60))
        [ "$mins" -lt 1 ] && mins=1
        time_ago="${mins} min"
        [ "$mins" -ne 1 ] && time_ago="${time_ago}s"
        time_ago="${time_ago} ago"
    fi

    # Print branch info in one line
    printf "%d) %-40s Last: %-20s Msg: %-50s\n" \
           "$i" "$branch" "$time_ago" "$last_commit_msg"

    # Store sorted branch info without epoch for later use
    branches[$i]="$branch|$last_commit_msg"

    ((i++))
done < <(printf '%s\n' "${branches[@]}" | sort -t'|' -k1n)

# Get user input
echo "Enter branch numbers to delete (comma-separated or range like 1-5):"
read -r input

# Convert range format (e.g. "1-5") to comma-separated list
if [[ $input =~ ^[0-9]+-[0-9]+$ ]]; then
    start=${input%-*}
    end=${input#*-}
    input=$(seq -s, "$start" "$end")
fi
# Convert input to array
IFS=',' read -ra indices <<< "$input"

echo -e "\nBranches to be deleted:"
echo "----------------------"

# Show selected branches first
branches_to_delete=()
for index in "${indices[@]}"; do
    index=$(echo "$index" | tr -d ' ')
    if [[ $index =~ ^[0-9]+$ ]] && [ "$index" -lt ${#branches[@]} ]; then
        IFS='|' read -r branch _rest <<< "${branches[$index]}"
        if is_protected "$branch"; then
            echo "Skipping protected branch: $branch"
            continue
        fi
        printf "%-30s\n" "$branch"
        branches_to_delete+=("$branch")
    else
        echo "Invalid index: $index"
    fi
done

if [[ ${#branches_to_delete[@]} -eq 0 ]]; then
    echo "No branches to delete."
    exit 0
fi

# Ask for confirmation
echo -e "\nProceed with deletion? [y/N] "
read -r confirm

if [[ $confirm =~ ^[Yy]$ ]]; then
    success=0
    failed=0
    for branch in "${branches_to_delete[@]}"; do
        if git branch -D "$branch" > /dev/null 2>&1; then
            ((success++))
        else
            echo "Failed to delete branch: $branch"
            ((failed++))
        fi
    done
    echo -e "\nDeletion complete:"
    echo "Successfully deleted: $success branch(es)"
    [[ $failed -gt 0 ]] && echo "Failed to delete: $failed branch(es)"
else
    echo "Operation cancelled"
fi
