#!/bin/bash
set -euo pipefail

# Quick WIP commit. Uses `git add -u` (tracked files only) to avoid
# accidentally staging untracked files like .env or build artifacts.

git add -u
if [ $# -eq 0 ]; then
    read -r -p "Enter commit message (default: WIP): " message
    if [ -z "$message" ]; then
        git commit -m "WIP"
    else
        git commit -m "$message"
    fi
else
    # Join all arguments with spaces to form the commit message
    commit_message="$*"
    git commit -m "$commit_message"
fi
